global proc delTwist(){
	string $twistJnts[] = `ls -type "joint" "*twist*" `;
	for($x in $twistJnts){
		catchQuiet(`cutKey  -attribute r -option keys $x`);
		setAttr ($x + ".r") 0 0 0;
	}
}

global proc udk_settimeline(){

	float $frameCount[];
	if(`objExists "spine_01"` == 0){
		string $sel[] = `ls -sl`;
		$frameCount = `keyframe -query -tc ( $sel[0] + ".rx")`;
	}else{
		$frameCount = `keyframe -query -tc "spine_01.rx"`;
	}
	playbackOptions -ast 0;
	playbackOptions -aet $frameCount[`size $frameCount` -1];
	playbackOptions -min 0 -max $frameCount[`size $frameCount` -1];


}


global proc delFootBall(){
	string $ballJnts[] = `ls -type "joint"  "ball_*"`;
	for($x in $ballJnts){
		catchQuiet(`cutKey  -attribute rotateX -option keys $x`);
		catchQuiet(`cutKey  -attribute rotateY -option keys $x`);
		setAttr ($x + ".rx") 0 ;
		setAttr ($x + ".ry") 0 ;
	}
}


global proc exportSel(){
		
	string $folderPath = "H:/0_WORK/0_UpWork/2_Underknown/Assets/finishMaya";  
	string $fileList[] = `getFileList -folder $folderPath`;
	for ($x in $fileList){
		file -f -options "v=0;"  -ignoreVersion  -typ "mayaAscii" -o ($folderPath + "/" + $x);
		string $fileName = `substitute "_v.*.ma" $x ""`;
		catchQuiet (`parent -w "root"`);
		delete "SKM_Manny_Simple" "Character1_Ctrl_Reference";
		udk_settimeline;
		select "root";
		file -force -options "v=0;p=17;f=0" -typ "FBX export" -pr -es ("H:/0_WORK/0_UpWork/2_Underknown/Assets/exportedFBX/"+ $fileName +"_RTG.fbx");
	}
	print "DONE!";
}


global proc arHipFix(){
	string $loc[] = `spaceLocator -n "toDel"`;
	string $pc[] = `parentConstraint "jnt_femaleFarmer_Hip" $loc[0] `;
	select -cl; select "jnt_femaleFarmer_Spine1";
	udk_settimeline;
	select -cl; select $loc[0];
	bakeCurrent;
	delete $pc;
	string $pc2[] = `parentConstraint $loc[0] "jnt_femaleFarmer_Hip"`;

	cutKey -cl -t ":" -f ":" -at "tx" -at "ty" -at "tz" -at "rx" -at "ry" -at "rz" "jnt_femaleFarmer_Root";
	setAttr "jnt_femaleFarmer_Root.rotateZ" 0;
	setAttr "jnt_femaleFarmer_Root.translateX" 0;
	setAttr "jnt_femaleFarmer_Root.translateY" 0;
	setAttr "jnt_femaleFarmer_Root.translateZ" 0;
	setAttr "jnt_femaleFarmer_Root.rotateX" 0;
	setAttr "jnt_femaleFarmer_Root.rotateY" 0;

	select -cl; select "jnt_femaleFarmer_Hip";
	bakeCurrent;
	delete $pc2 $loc;
}


global proc UIudkTool(){
	if (`window -exists udkWindow`) {
		deleteUI udkWindow;
	}

	window -title "Underknown Tool" -widthHeight 300 150 udkWindow;

	gridLayout -numberOfColumns 3 -cellWidthHeight 100 50;

	button -label "IK Leg" -command "ikLegs";
	button -label "IK Arm" -command "ikArms";
	button -label "Del IK" -command "deleteRtgIk 0";
	button -label "Bake + Del IK" -command "deleteRtgIk 1";
	button -label "PConst mo" -command "parentConstMo";
	button -label "Bake Select" -command "bakeCurrent";
	button -label "Del Twist Jnts" -command "delTwist";
	button -label "Fix Hand" -command "fixHand";
	button -label "Set Timeline" -command "udk_settimeline";
	button -label "Del Rot Balls" -command "delFootBall";
	button -label "Batch Export" -command "exportSel";
	button -label "RTG Exec" -command "Chase_rtgRawAnim";
	button -label "AR Hip fix" -command "arHipFix";
	

	showWindow udkWindow;

}