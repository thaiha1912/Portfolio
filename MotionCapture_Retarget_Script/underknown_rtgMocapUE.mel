global proc Chase_copAnim(string $charNamespace){
	string $child[] = `listRelatives -ad -type "transform" "root"`;
	for ($x in $child){
		if ($x == "pelvis"){
			catchQuiet (`parentConstraint -n "consToDel" ($charNamespace + "_" + $x) $x`);
		}else{
			catchQuiet (`orientConstraint -n "consToDel" ($charNamespace + "_" + $x) $x`);
		}
		
	}
	float $frameCount[] = `keyframe -query -tc ( $child[0] + ".rx")`;
	string $timeRange = "0:" + $frameCount[`size $frameCount` -1];

	playbackOptions -aet $frameCount[`size $frameCount` -1];
	playbackOptions -ast 0;

	bakeResults -simulation true -t $timeRange -sampleBy 1 -oversamplingRate 1 -disableImplicitControl true -preserveOutsideKeys true -sparseAnimCurveBake false -removeBakedAttributeFromLayer false -removeBakedAnimFromLayer false -bakeOnOverrideLayer false -minimizeRotation true -controlPoints false -shape true $child;
	
	string $del[] = `ls "consToDel" ($charNamespace + "*")`;
	catchQuiet (`delete $del`);
	
}

global proc Chase_rtgRawAnim(){
	string $baseSke =  "H:/0_WORK/0_UpWork/2_Underknown/Assets/rtgMannequinUE5_Rig.ma";
	string $listAnim[] = `getFBXFiles "H:/0_WORK/0_UpWork/2_Underknown/Assets/Raw Mocap VenusMercuryMars"`;

	for ($x in $listAnim){
		$x = substituteAllString($x, "\n", "");
		$x = substituteAllString($x, "\r", "");

		string $fileName = `substitute ".fbx" $x ""`;
		$fileName = `match "[^/\\\\]+$" $fileName `;

		file -f -options "v=0;"  -ignoreVersion  -typ "mayaAscii" -o $baseSke;
		file -import -type "FBX"  -ignoreVersion -ra true -mergeNamespacesOnClash false -options "fbx" -rpr $fileName -importFrameRate true -pr -importTimeRange "combine" $x;
		file -import -type "FBX"  -ignoreVersion -options "fbx" "H:/0_WORK/0_UpWork/2_Underknown/Assets/chaseProxy.fbx";

		Chase_copAnim $fileName;

		delTwist;
		delFootBall;
		fixHand;
		DeleteAllStaticChannels;
		udk_settimeline;

		delete "Body" "HeadFaceless";

		string $directoryPath = `match "^(.*[/])" $x`;

		string $outputFileName = ($directoryPath + $fileName +"_v.000.ma");
		file -rename $outputFileName;
		file -f -save  -options "v=0;";
	}
	
}

global proc string[] getFBXFiles(string $directory) {
	string $allFBXFiles[];

	string $foldersList = `system("dir \"" + $directory + "\" /b /ad")`;
	string $folders[];
	tokenize($foldersList, "\n", $folders);

	for ($folder in $folders) {
		if ($folder != "") {
			string $folderPath = $directory + "/" + $folder;
			string $fbxFilesList = `system("dir \"" + $folderPath + "\\*.fbx\" /b")`;

			string $fbxFiles[];
			tokenize($fbxFilesList, "\n", $fbxFiles);	

			for ($file in $fbxFiles) {
				if ($file != "") {
					$folderPath = substituteAllString($folderPath, "\n", "");
					$folderPath = substituteAllString($folderPath, "\r", "");
					string $filePath = $folderPath + "/" + $file;

					$allFBXFiles[size($allFBXFiles)] = $filePath;
				}
			}
		}
	}

	return $allFBXFiles;
}


global proc ikLegs(){
	string $select [] = `ls -sl`;
	string $dupIt[] = `duplicate -po -rc $select`;
	string $kneeName = ("loc_" + $dupIt[1]) ;
	for ($x in $dupIt){
		string $loc[] = `spaceLocator -n ("loc_" + $x)`;
		string $locChild[] = `spaceLocator -n ("locChild_" + $x)`;
		parent $locChild[0] $loc[0];
		parentConstraint -n "toDel" $x $loc[0];
		delete "toDel";
	}
	string $ball[] =`duplicate -rc -n ("loc_ball_" + $dupIt[3]) ("loc_" + $dupIt[3])`;

	aimConstraint -n "toDel" -offset 0 0 0 -weight 1 -aimVector 0 0 -1 -upVector 0 1 0 -worldUpType "vector" -worldUpVector 0 1 0 $dupIt[2] ("loc_" + $dupIt[3]) ;
	delete "toDel";

	if ($kneeName == ""){
		print "\n\nKNEE PAIN\n\n";
	}else{
		hn_pythonFindPoleVec  $select [0] $select [1] $select [2] $kneeName;

		select $dupIt;
		makeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1;

		select -cl; select  $dupIt[0] $dupIt[2];
		string $footIk[] = `ikHandle -n ("ikRTG_"+ $dupIt[0]) -sol ikRPsolver`;
		poleVectorConstraint ("locChild_" + $dupIt[1]) $footIk[0];
		setAttr ($footIk[0] + ".v" ) 0;

		parent $footIk[0] ("locChild_" + $dupIt[3]);
		parent $dupIt[0] ("locChild_" + $dupIt[0]);

		delete  $dupIt[3] ("loc_" + $dupIt[2]);

		parentConstraint -n "toDel" -mo $select[1] $kneeName;
		parentConstraint  -mo "pelvis"  ("loc_" + $dupIt[0]);
		pointConstraint -n "toDel" -mo $select[3] ("loc_" + $dupIt[3]);
		aimConstraint -n "toDel" -offset 0 0 0 -weight 1 -aimVector 0 0 -1 -upVector 0 1 0 -worldUpType "vector" -worldUpVector 0 1 0 $select[2] ("loc_" + $dupIt[3]) ;

		string $upVec[] = `duplicate -po -name ("jnt_upVec_" + $select[2] ) $select[2]`;
		parent $upVec[0] $select[2];
		setAttr ($upVec[0] + ".tz") 30;
		parent  $upVec ("locChild_" + $dupIt[3]); 
		// parentConstraint -mo -n "toDel" $select[2] $upVec[0] ;

		aimConstraint -offset 0 0 0 -weight 1 -aimVector 0 0 1 -upVector 1 0 0 -worldUpType "object" -worldUpObject $upVec[0] ("locChild_" + $dupIt[3]) $dupIt[2];

		parentConstraint -n "del" $select[3] $ball[0]; delete "del";
		parent $ball[0] $select[3]; 
		setAttr ($ball[1] + ".tz") 30; parent -w $ball[1];
		setAttr ($ball[0] + ".tx") -30; parent -w $ball[0];
		parent $ball[1] $ball[0];

		parentConstraint -mo -n "toDel" -skipTranslate y -weight 1  $select[3] $ball[0];

		float $frameCount[] = `keyframe -query -tc ( $select[0] + ".rx")`;
		string $timeRange = "0:" + $frameCount[`size $frameCount` -1];

		bakeResults -simulation true -t $timeRange -sampleBy 1 -oversamplingRate 1 -disableImplicitControl true -preserveOutsideKeys true -sparseAnimCurveBake false -removeBakedAttributeFromLayer false -removeBakedAnimFromLayer false -bakeOnOverrideLayer false -minimizeRotation true -controlPoints false -shape true {("loc_" + $dupIt[3]) ,  ("loc_" + $dupIt[1]),  $ball[0] };

		delete `ls "*toDel*"`;

		orientConstraint -mo $dupIt[0] $select[0];
		orientConstraint  -mo $dupIt[1] $select[1];
		orientConstraint -mo $dupIt[2] $select[2];
		aimConstraint  -offset 0 0 0 -weight 1 -aimVector -1 0 0 -upVector 0 0 1 -worldUpType "object" -worldUpObject $ball[1]  $ball[0] $select[3]  ;
		select -cl;
	}

}

global proc hn_pythonFindPoleVec(string $upper , string $knee, string $foot, string $poleLoc){
	string $cmd1 = "from maya import cmds as cmds;from maya import OpenMaya as om;";
	string $cmd2 = ("posA = om.MVector(*cmds.xform(\""+ $upper +"\", q=True, ws=True, t=True))");
	string $cmd3 = ("posB = om.MVector(*cmds.xform(\""+ $knee +"\", q=True, ws=True, t=True))");
	string $cmd4 = ("posC = om.MVector(*cmds.xform(\""+ $foot +"\", q=True, ws=True, t=True))");
	string $cmd5 = "AC = posC - posA;AB = posB - posA;BC = posC - posB;multiplier = (AC*AB)/(AC*AC);projection = AC * multiplier + posA;direction = (posB - projection).normal();total_length = AB.length() + BC.length();pos = posB + (direction*total_length)";
	string $cmd6 = ("cmds.xform(\" " + $poleLoc + "\", t=[pos.x, pos.y, pos.z], ws=True)");

	python($cmd1);
	python($cmd2);
	python($cmd3);
	python($cmd4);
	python($cmd5);
	python($cmd6);
}


global proc ikArms(){
	string $select [] = `ls -sl`;
	string $dupIt[] = `duplicate -po -rc $select`;
	string $elbowName = ("loc_" + $dupIt[1]) ;
	for ($x in $dupIt){
		string $loc[] = `spaceLocator -n ("loc_" + $x)`;
		string $locChild[] = `spaceLocator -n ("locChild_" + $x)`;
		parent $locChild[0] $loc[0];
		parentConstraint -n "toDel" $x $loc[0];
		delete "toDel";
	}

	if ($elbowName == ""){
		print "\n\nElBOW PAIN\n\n";
	}else{
		hn_pythonFindPoleVec  $select [0] $select [1] $select [2] $elbowName;
		select $dupIt;
		makeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1;

		select -cl; select  $dupIt[0] $dupIt[2];
		string $elbowIk[] = `ikHandle -n ("ikRTG_"+ $dupIt[0]) -sol ikRPsolver`;
		poleVectorConstraint ("locChild_" + $dupIt[1]) $elbowIk[0];
		setAttr ($elbowIk[0] + ".v" ) 0;

		parent $elbowIk[0] ("locChild_" + $dupIt[2]);
		parent $dupIt[0] ("locChild_" + $dupIt[0]);

		string $clavName[] = `listRelatives -p $select[0]`;
		parentConstraint -n "toDel" -mo $select[1] $elbowName;
		parentConstraint  -mo $clavName[0]  ("loc_" + $dupIt[0]);
		parentConstraint -n "toDel" -mo $select[2] ("loc_" + $dupIt[2]);

		string $dupWrist[] = `duplicate -po -rc -n ("jnt_" + $dupIt[2])  $dupIt[2]`;
		parent $dupWrist[0] ("locChild_" + $dupIt[2]);

		float $frameCount[] = `keyframe -query -tc ( $select[0] + ".rx")`;
		string $timeRange = "0:" + $frameCount[`size $frameCount` -1];

		bakeResults -simulation true -t $timeRange -sampleBy 1 -oversamplingRate 1 -disableImplicitControl true -preserveOutsideKeys true -sparseAnimCurveBake false -removeBakedAttributeFromLayer false -removeBakedAnimFromLayer false -bakeOnOverrideLayer false -minimizeRotation true -controlPoints false -shape true { ("loc_" + $dupIt[1]), ("loc_" + $dupIt[2])};

		delete `ls "*toDel*"`;

		orientConstraint  -mo $dupIt[0] $select[0];
		orientConstraint  -mo $dupIt[1] $select[1];
		parentConstraint  -mo $dupWrist[0] $select[2];
	}
	
}

global proc deleteRtgIk(int $bake){
	if($bake == 1){
		string $ske[] = `listRelatives -ad -pa -type "joint" "root*"`;

		float $frameCount[] = `keyframe -query -tc ( $ske[0] + ".rx")`;
		string $timeRange = "0:" + $frameCount[`size $frameCount` -1];

		bakeResults -simulation true -t $timeRange -sampleBy 1 -oversamplingRate 1 -disableImplicitControl true -preserveOutsideKeys true -sparseAnimCurveBake false -removeBakedAttributeFromLayer false -removeBakedAnimFromLayer false -bakeOnOverrideLayer false -minimizeRotation true -controlPoints false -shape true $ske;

		print "\nDONE BAKE\n";
	}

	delete `ls "toDel*" "loc_*" "jnt_*" `;
	
}

global proc parentConstMo(){
	string $sel[] = `ls -sl`;
	parentConstraint -mo -n "RTG_toDel" $sel[0] $sel[1];
}

global proc bakeCurrent(){
	int $end = `playbackOptions -q -max`; 
	int $start = `playbackOptions -q -min `;
	string $timeRange = $start + ":"+ $end;
	string $sel [] = `ls -sl`;

	bakeResults -simulation true -t $timeRange -sampleBy 1 -oversamplingRate 1 -disableImplicitControl true -preserveOutsideKeys true -sparseAnimCurveBake false -removeBakedAttributeFromLayer false -removeBakedAnimFromLayer false -bakeOnOverrideLayer false -minimizeRotation true -controlPoints false -shape true $sel;

	catchQuiet(`delete "RTG_toDel"`);

}



